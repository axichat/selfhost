[Unit]
Description=Stalwart Mail Server
After=network-online.target docker.service
Wants=network-online.target docker.service

[Service]
Type=simple
Restart=always
RestartSec=3
TimeoutStartSec=0
ExecStartPre=-/usr/bin/docker rm -f stalwart
ExecStart=/usr/bin/docker run --name stalwart --rm --log-driver=journald --cap-drop=ALL --cap-add=NET_BIND_SERVICE -p 0.0.0.0:25:25 -p 0.0.0.0:587:587 -p 0.0.0.0:465:465 -p 0.0.0.0:993:993 -p 127.0.0.1:8080:8080 -v /var/lib/stalwart:/opt/stalwart stalwartlabs/stalwart:v0.15.4
ExecStop=/usr/bin/docker stop stalwart

[Install]
WantedBy=multi-user.target
